# ── Copy this file to .env and fill in your credentials ───────────────────────
# docker-compose.yml loads bot/.env explicitly via env_file.

# ── API credentials ────────────────────────────────────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Telegram signal notifications. Leave blank to disable.
# Telegram forum topics are supported as <chat_id>_<message_thread_id>,
# for example -1003755718647_118.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ACCEPTED_SIGNALS_CHAT_ID=
TELEGRAM_REJECTED_SIGNALS_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# ── Trading mode ───────────────────────────────────────────────────────────────
# true  → Bybit Demo Trading  (api-demo.bybit.com) — simulated funds, real market data
# false → Live Trading        (api.bybit.com)       — REAL FUNDS, use with caution!
BYBIT_DEMO=true
# Required explicit guard for live mode. Leave false in demo.
# If BYBIT_DEMO=false and this is not true, the bot exits before trading startup.
LIVE_TRADING_CONFIRM=false

# ── Risk / sizing ──────────────────────────────────────────────────────────────
# Target account loss at the initial stop-loss as a fraction of equity.
# 0.01 = a trade hitting SL should lose about 1% of equity.
NOTIONAL_PCT=0.01
MIN_STOP_DISTANCE_PCT=0.001
TAKER_FEE_RATE=0.00055
MAX_FEE_TO_PRICE_RISK=0.25
ORDER_LEVERAGE_BUFFER=2.0
WS_STALE_SECONDS=900

# Maximum number of positions open simultaneously across all strategies.
MAX_OPEN_POSITIONS=5
MAX_CLUSTER_A=3

# Drawdown guards. MAX_WEEKLY_DD=0 disables the weekly guard.
MAX_DAILY_DD=0.05
MAX_WEEKLY_DD=0.0
DD_CLOSE_POSITIONS_ON_BREACH=true

# Public market-data WS. Keep false in demo mode because Bybit demo public WS
# can return 404 for linear kline streams.
BYBIT_PUBLIC_WS_DEMO=false

# Private order/position WS for fill notifications. Demo private WS is available.
ENABLE_PRIVATE_ORDER_WS=true
BYBIT_PRIVATE_WS_DEMO=true
TELEGRAM_NOTIFY_ENTRY_FILLS=false
PRIVATE_POSITION_ENTRY_DEBOUNCE_SECONDS=10
PROTECTION_AUDIT_SECONDS=300
# Admin-only open-order sanity audit interval. 0 disables.
OPEN_ORDER_AUDIT_SECONDS=300
DAILY_HEARTBEAT_UTC_HOUR=0
DAILY_HEARTBEAT_UTC_MINUTE=5
MAX_DAILY_LOSSES_PER_STRATEGY=0
MAX_DAILY_LOSSES_PER_SYMBOL=0
MAX_CONSECUTIVE_LOSSES_PER_STRATEGY=0
MAX_CONSECUTIVE_LOSSES_PER_SYMBOL=0

# Strategy toggles.
ENABLE_TURTLE_SOUP=true
TURTLE_SYMBOLS=BNBUSDT,TAOUSDT,LINKUSDT,BTCUSDT,ETHUSDT,SOLUSDT

# Keep false for fail-closed behavior: if a Million Moves symbol has use_dt=true
# but no accepted DT model file, do not trade it as trail-only.
ALLOW_MM_WITHOUT_DT=false

ENABLE_SESSION_ORB=true
SESSION_ORB_SYMBOLS=ETHUSDT,WIFUSDT,NEARUSDT,ENAUSDT,OPUSDT,ONDOUSDT
SESSION_ORB_THRESHOLD=0.50
SESSION_ORB_WARMUP_BARS=20000
SESSION_ORB_BLOCK_WEEKEND_SESSIONS=asia,london
