//@version=6
strategy(
    title                   = "Crypto Regime Pullback Strategy",
    shorttitle              = "CryPull",
    overlay                 = true,
    pyramiding              = 0,
    initial_capital         = 10000,
    default_qty_type        = strategy.percent_of_equity,
    default_qty_value       = 10,
    commission_type         = strategy.commission.percent,
    commission_value        = 0.06,
    slippage                = 2,
    calc_on_every_tick      = false,
    process_orders_on_close = false,
    max_bars_back           = 3000
)

grp_exec = "Execution"
i_use_session = input.bool(false, "Use UTC session filter", group = grp_exec)
i_session = input.session("0000-2359", "Session (UTC)", group = grp_exec)
i_cooldown_bars = input.int(4, "Cooldown bars", minval = 1, maxval = 100, group = grp_exec)
i_allow_longs = input.bool(true, "Enable longs", group = grp_exec)
i_allow_shorts = input.bool(true, "Enable shorts", group = grp_exec)

grp_regime = "Regime"
i_use_htf = input.bool(true, "Use HTF regime", group = grp_regime)
i_htf = input.timeframe("240", "HTF timeframe", group = grp_regime)
i_htf_fast_len = input.int(50, "HTF fast EMA", minval = 10, maxval = 200, group = grp_regime)
i_htf_slow_len = input.int(200, "HTF slow EMA", minval = 50, maxval = 400, group = grp_regime)
i_htf_rsi_len = input.int(14, "HTF RSI length", minval = 2, maxval = 50, group = grp_regime)
i_htf_rsi_bull = input.int(52, "HTF RSI bull threshold", minval = 45, maxval = 70, group = grp_regime)
i_htf_rsi_bear = input.int(48, "HTF RSI bear threshold", minval = 30, maxval = 55, group = grp_regime)

grp_signal = "Signal"
i_fast_ema_len = input.int(20, "Fast EMA", minval = 5, maxval = 100, group = grp_signal)
i_slow_ema_len = input.int(50, "Slow EMA", minval = 10, maxval = 200, group = grp_signal)
i_rsi_len = input.int(14, "Signal RSI length", minval = 2, maxval = 50, group = grp_signal)
i_long_rsi_min = input.int(52, "Min RSI for longs", minval = 40, maxval = 80, group = grp_signal)
i_short_rsi_max = input.int(48, "Max RSI for shorts", minval = 20, maxval = 60, group = grp_signal)
i_use_adx = input.bool(true, "Use ADX trend-strength filter", group = grp_signal)
i_adx_len = input.int(14, "ADX length", minval = 5, maxval = 50, group = grp_signal)
i_min_adx = input.float(18.0, "Min ADX", minval = 5.0, maxval = 50.0, step = 0.5, group = grp_signal)
i_pullback_lookback = input.int(8, "Pullback lookback bars", minval = 2, maxval = 30, group = grp_signal)
i_breakout_lookback = input.int(3, "Breakout lookback bars", minval = 1, maxval = 10, group = grp_signal)
i_touch_buffer_atr = input.float(0.10, "EMA touch buffer (ATR)", minval = 0.0, maxval = 1.0, step = 0.01, group = grp_signal)
i_max_depth_atr = input.float(0.45, "Max depth beyond slow EMA (ATR)", minval = 0.05, maxval = 2.0, step = 0.05, group = grp_signal)
i_min_close_pos = input.float(0.60, "Min close position in bar", minval = 0.50, maxval = 0.95, step = 0.05, group = grp_signal)
i_require_reclaim = input.bool(true, "Require reclaim of fast EMA", group = grp_signal)

grp_risk = "Risk"
i_stop_buffer_atr = input.float(0.10, "Stop buffer (ATR)", minval = 0.02, maxval = 1.0, step = 0.01, group = grp_risk)
i_rr = input.float(2.2, "Target RR", minval = 1.2, maxval = 5.0, step = 0.1, group = grp_risk)
i_use_be = input.bool(true, "Move stop to breakeven at 1R", group = grp_risk)
i_be_rr = input.float(1.0, "Breakeven trigger RR", minval = 0.5, maxval = 3.0, step = 0.25, group = grp_risk)
i_max_hold_bars = input.int(36, "Max bars in trade", minval = 2, maxval = 200, group = grp_risk)

in_session = not i_use_session or not na(time(timeframe.period, i_session, "UTC"))
atr = ta.atr(14)
bar_range = math.max(high - low, syminfo.mintick)
close_pos = (close - low) / bar_range
rsi = ta.rsi(close, i_rsi_len)
ema_fast = ta.ema(close, i_fast_ema_len)
ema_slow = ta.ema(close, i_slow_ema_len)
[_, _, adx] = ta.dmi(i_adx_len, i_adx_len)

// Completed HTF bars only.
htf_close = request.security(syminfo.tickerid, i_htf, close[1], lookahead = barmerge.lookahead_off)
htf_fast = request.security(syminfo.tickerid, i_htf, ta.ema(close, i_htf_fast_len)[1], lookahead = barmerge.lookahead_off)
htf_slow = request.security(syminfo.tickerid, i_htf, ta.ema(close, i_htf_slow_len)[1], lookahead = barmerge.lookahead_off)
htf_rsi = request.security(syminfo.tickerid, i_htf, ta.rsi(close, i_htf_rsi_len)[1], lookahead = barmerge.lookahead_off)

htf_bull = htf_close >= htf_slow and htf_fast >= htf_slow and htf_rsi >= i_htf_rsi_bull
htf_bear = htf_close <= htf_slow and htf_fast <= htf_slow and htf_rsi <= i_htf_rsi_bear
regime_bull = (not i_use_htf or htf_bull) and ema_fast >= ema_slow and close >= ema_slow
regime_bear = (not i_use_htf or htf_bear) and ema_fast <= ema_slow and close <= ema_slow
adx_ok = not i_use_adx or adx >= i_min_adx

pullback_low = ta.lowest(low, i_pullback_lookback)
pullback_high = ta.highest(high, i_pullback_lookback)
recent_touch_long = pullback_low <= ema_fast + atr * i_touch_buffer_atr
recent_touch_short = pullback_high >= ema_fast - atr * i_touch_buffer_atr
pullback_valid_long = pullback_low >= ema_slow - atr * i_max_depth_atr
pullback_valid_short = pullback_high <= ema_slow + atr * i_max_depth_atr
reclaim_long_ok = not i_require_reclaim or close >= ema_fast
reclaim_short_ok = not i_require_reclaim or close <= ema_fast
breakout_long_level = ta.highest(high[1], i_breakout_lookback)
breakout_short_level = ta.lowest(low[1], i_breakout_lookback)

var int last_signal_bar = na
var float pending_stop = na
var float active_stop = na
var float active_target = na
var float active_risk = na
var int active_entry_bar = na

cooldown_ok = na(last_signal_bar) or (bar_index - last_signal_bar) >= i_cooldown_bars

long_signal = i_allow_longs and barstate.isconfirmed and in_session and cooldown_ok and strategy.position_size == 0 and regime_bull and adx_ok and recent_touch_long and pullback_valid_long and close > breakout_long_level and close > open and close_pos >= i_min_close_pos and rsi >= i_long_rsi_min and reclaim_long_ok
short_signal = i_allow_shorts and barstate.isconfirmed and in_session and cooldown_ok and strategy.position_size == 0 and regime_bear and adx_ok and recent_touch_short and pullback_valid_short and close < breakout_short_level and close < open and close_pos <= 1.0 - i_min_close_pos and rsi <= i_short_rsi_max and reclaim_short_ok

if long_signal
    stop_candidate = pullback_low - atr * i_stop_buffer_atr
    if close - stop_candidate > syminfo.mintick * 4
        pending_stop := stop_candidate
        last_signal_bar := bar_index
        strategy.entry("Long", strategy.long)

if short_signal
    stop_candidate = pullback_high + atr * i_stop_buffer_atr
    if stop_candidate - close > syminfo.mintick * 4
        pending_stop := stop_candidate
        last_signal_bar := bar_index
        strategy.entry("Short", strategy.short)

new_long_fill = strategy.position_size > 0 and strategy.position_size[1] <= 0
new_short_fill = strategy.position_size < 0 and strategy.position_size[1] >= 0

if new_long_fill
    active_stop := math.min(pending_stop, strategy.position_avg_price - syminfo.mintick)
    active_risk := strategy.position_avg_price - active_stop
    active_target := strategy.position_avg_price + active_risk * i_rr
    active_entry_bar := bar_index
    pending_stop := na

if new_short_fill
    active_stop := math.max(pending_stop, strategy.position_avg_price + syminfo.mintick)
    active_risk := active_stop - strategy.position_avg_price
    active_target := strategy.position_avg_price - active_risk * i_rr
    active_entry_bar := bar_index
    pending_stop := na

if strategy.position_size > 0 and i_use_be and not na(active_risk) and high >= strategy.position_avg_price + active_risk * i_be_rr
    active_stop := math.max(active_stop, strategy.position_avg_price)

if strategy.position_size < 0 and i_use_be and not na(active_risk) and low <= strategy.position_avg_price - active_risk * i_be_rr
    active_stop := math.min(active_stop, strategy.position_avg_price)

if strategy.position_size > 0 and not na(active_stop) and not na(active_target)
    strategy.exit("Long-X", "Long", stop = active_stop, limit = active_target)

if strategy.position_size < 0 and not na(active_stop) and not na(active_target)
    strategy.exit("Short-X", "Short", stop = active_stop, limit = active_target)

bars_in_trade = strategy.position_size != 0 and not na(active_entry_bar) ? bar_index - active_entry_bar : 0

if strategy.position_size > 0 and bars_in_trade >= i_max_hold_bars
    strategy.close("Long", comment = "TimeStop")

if strategy.position_size < 0 and bars_in_trade >= i_max_hold_bars
    strategy.close("Short", comment = "TimeStop")

if strategy.position_size == 0 and strategy.position_size[1] != 0
    active_stop := na
    active_target := na
    active_risk := na
    active_entry_bar := na

plot(ema_fast, "EMA Fast", color = color.new(color.orange, 0))
plot(ema_slow, "EMA Slow", color = color.new(color.red, 10))
plotshape(long_signal, title = "Long Signal", style = shape.triangleup, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny, text = "L")
plotshape(short_signal, title = "Short Signal", style = shape.triangledown, location = location.abovebar, color = color.new(color.maroon, 0), size = size.tiny, text = "S")
bgcolor(in_session ? na : color.new(color.gray, 92), title = "Out of Session")
