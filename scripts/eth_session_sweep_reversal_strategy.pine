//@version=6
strategy(
    title                   = "ETH Session Sweep Reversal RR+",
    shorttitle              = "ETHSSR",
    overlay                 = true,
    pyramiding              = 0,
    initial_capital         = 10000,
    default_qty_type        = strategy.percent_of_equity,
    default_qty_value       = 10,
    commission_type         = strategy.commission.percent,
    commission_value        = 0.06,
    slippage                = 2,
    calc_on_every_tick      = false,
    process_orders_on_close = false,
    max_bars_back           = 3000
)

// Recommended chart: BINANCE:ETHUSDT on 15m.
// Strategy family: build the Asia session range, wait for a liquidity sweep,
// and enter only after price reclaims back inside the range with HTF bias.

//------------------------------------------------------------------------------
// Inputs
//------------------------------------------------------------------------------
grp_time = "Sessions"
i_range_session = input.session("0000-0600", "Range session (UTC)", group = grp_time)
i_trade_session = input.session("0600-1800", "Trade session (UTC)", group = grp_time)
i_one_trade_per_day = input.bool(true, "Max one trade per day", group = grp_time)
i_flat_after_session = input.bool(true, "Flat after trade session", group = grp_time)
i_flat_new_day = input.bool(true, "Flat on new day", group = grp_time)

grp_bias = "Bias"
i_htf = input.timeframe("60", "HTF bias timeframe", group = grp_bias)
i_htf_ema_len = input.int(200, "HTF EMA length", minval = 50, maxval = 400, group = grp_bias)
i_htf_rsi_len = input.int(14, "HTF RSI length", minval = 2, maxval = 50, group = grp_bias)
i_htf_rsi_bull = input.int(52, "HTF RSI bull threshold", minval = 45, maxval = 70, group = grp_bias)
i_htf_rsi_bear = input.int(48, "HTF RSI bear threshold", minval = 30, maxval = 55, group = grp_bias)

grp_filter = "Filters"
i_signal_rsi_len = input.int(14, "Signal RSI length", minval = 2, maxval = 50, group = grp_filter)
i_signal_rsi_long = input.int(50, "Long reclaim RSI", minval = 40, maxval = 65, group = grp_filter)
i_signal_rsi_short = input.int(50, "Short reclaim RSI", minval = 35, maxval = 60, group = grp_filter)
i_vol_len = input.int(20, "Volume SMA length", minval = 5, maxval = 100, group = grp_filter)
i_vol_mult = input.float(0.85, "Signal volume / SMA", minval = 0.5, step = 0.05, group = grp_filter)
i_sweep_atr = input.float(0.10, "Minimum sweep ATR", minval = 0.02, step = 0.01, group = grp_filter)
i_confirm_bars = input.int(2, "Bars from sweep to reclaim", minval = 1, maxval = 8, group = grp_filter)
i_wick_fraction = input.float(0.35, "Min rejection wick fraction", minval = 0.1, maxval = 0.8, step = 0.05, group = grp_filter)

grp_risk = "Risk"
i_rr = input.float(1.5, "Target RR", minval = 1.5, step = 0.1, group = grp_risk)
i_stop_atr = input.float(0.12, "Stop ATR buffer", minval = 0.05, step = 0.01, group = grp_risk)
i_max_hold_bars = input.int(12, "Max bars in trade", minval = 1, maxval = 100, group = grp_risk)

//------------------------------------------------------------------------------
// Core calculations
//------------------------------------------------------------------------------
atr = ta.atr(14)
vwap_val = ta.vwap(hlc3)
signal_rsi = ta.rsi(close, i_signal_rsi_len)
vol_sma = ta.sma(volume, i_vol_len)

in_range = not na(time(timeframe.period, i_range_session, "UTC"))
in_trade = not na(time(timeframe.period, i_trade_session, "UTC"))
range_ended = not in_range and in_range[1]
trade_session_ended = not in_trade and in_trade[1]
new_day = ta.change(time("D")) != 0

// Use only completed higher-timeframe bars.
htf_close = request.security(syminfo.tickerid, i_htf, close[1], lookahead = barmerge.lookahead_off)
htf_ema = request.security(syminfo.tickerid, i_htf, ta.ema(close, i_htf_ema_len)[1], lookahead = barmerge.lookahead_off)
htf_rsi = request.security(syminfo.tickerid, i_htf, ta.rsi(close, i_htf_rsi_len)[1], lookahead = barmerge.lookahead_off)

bias_bull = htf_close > htf_ema and htf_rsi >= i_htf_rsi_bull
bias_bear = htf_close < htf_ema and htf_rsi <= i_htf_rsi_bear
vol_ok = volume >= vol_sma * i_vol_mult

bar_range = math.max(high - low, syminfo.mintick)
lower_wick_frac = (math.min(open, close) - low) / bar_range
upper_wick_frac = (high - math.max(open, close)) / bar_range

//------------------------------------------------------------------------------
// Day and setup state
//------------------------------------------------------------------------------
var float day_range_high = na
var float day_range_low = na
var bool range_ready = false
var bool trade_taken_today = false

var bool long_setup_active = false
var bool short_setup_active = false
var float long_sweep_low = na
var float short_sweep_high = na
var int long_sweep_bar = na
var int short_sweep_bar = na

var float pending_stop = na
var float active_stop = na
var float active_target = na
var int active_entry_bar = na

if new_day
    day_range_high := na
    day_range_low := na
    range_ready := false
    trade_taken_today := false
    long_setup_active := false
    short_setup_active := false
    long_sweep_low := na
    short_sweep_high := na
    long_sweep_bar := na
    short_sweep_bar := na

if new_day and i_flat_new_day and strategy.position_size != 0
    strategy.close_all(comment = "NewDay")

if in_range
    day_range_high := na(day_range_high) ? high : math.max(day_range_high, high)
    day_range_low := na(day_range_low) ? low : math.min(day_range_low, low)

if range_ended and not na(day_range_high) and not na(day_range_low)
    range_ready := true

//------------------------------------------------------------------------------
// Sweep and reclaim logic
//------------------------------------------------------------------------------
long_sweep = barstate.isconfirmed and range_ready and in_trade and not trade_taken_today and bias_bull and low < day_range_low - atr * i_sweep_atr and close > day_range_low and close > open and lower_wick_frac >= i_wick_fraction
short_sweep = barstate.isconfirmed and range_ready and in_trade and not trade_taken_today and bias_bear and high > day_range_high + atr * i_sweep_atr and close < day_range_high and close < open and upper_wick_frac >= i_wick_fraction

if long_sweep
    long_setup_active := true
    short_setup_active := false
    long_sweep_low := low
    long_sweep_bar := bar_index
    short_sweep_high := na
    short_sweep_bar := na

if short_sweep
    short_setup_active := true
    long_setup_active := false
    short_sweep_high := high
    short_sweep_bar := bar_index
    long_sweep_low := na
    long_sweep_bar := na

if long_setup_active and not na(long_sweep_bar) and (bar_index - long_sweep_bar) > i_confirm_bars
    long_setup_active := false

if short_setup_active and not na(short_sweep_bar) and (bar_index - short_sweep_bar) > i_confirm_bars
    short_setup_active := false

can_trade_today = not i_one_trade_per_day or not trade_taken_today

long_signal = barstate.isconfirmed and in_trade and strategy.position_size == 0 and can_trade_today and long_setup_active and not na(long_sweep_bar) and bar_index > long_sweep_bar and close > high[1] and close > day_range_low and close > vwap_val and signal_rsi >= i_signal_rsi_long and vol_ok
short_signal = barstate.isconfirmed and in_trade and strategy.position_size == 0 and can_trade_today and short_setup_active and not na(short_sweep_bar) and bar_index > short_sweep_bar and close < low[1] and close < day_range_high and close < vwap_val and signal_rsi <= i_signal_rsi_short and vol_ok

if long_signal
    stop_candidate = long_sweep_low - atr * i_stop_atr
    if close - stop_candidate > syminfo.mintick * 4
        pending_stop := stop_candidate
        strategy.entry("Long", strategy.long)
        trade_taken_today := true
        long_setup_active := false

if short_signal
    stop_candidate = short_sweep_high + atr * i_stop_atr
    if stop_candidate - close > syminfo.mintick * 4
        pending_stop := stop_candidate
        strategy.entry("Short", strategy.short)
        trade_taken_today := true
        short_setup_active := false

new_long_fill = strategy.position_size > 0 and strategy.position_size[1] <= 0
new_short_fill = strategy.position_size < 0 and strategy.position_size[1] >= 0

if new_long_fill
    active_stop := math.min(pending_stop, strategy.position_avg_price - syminfo.mintick)
    risk = strategy.position_avg_price - active_stop
    active_target := strategy.position_avg_price + risk * i_rr
    active_entry_bar := bar_index
    pending_stop := na

if new_short_fill
    active_stop := math.max(pending_stop, strategy.position_avg_price + syminfo.mintick)
    risk = active_stop - strategy.position_avg_price
    active_target := strategy.position_avg_price - risk * i_rr
    active_entry_bar := bar_index
    pending_stop := na

if strategy.position_size > 0 and not na(active_stop) and not na(active_target)
    strategy.exit("Long-X", "Long", stop = active_stop, limit = active_target)

if strategy.position_size < 0 and not na(active_stop) and not na(active_target)
    strategy.exit("Short-X", "Short", stop = active_stop, limit = active_target)

bars_in_trade = strategy.position_size != 0 and not na(active_entry_bar) ? bar_index - active_entry_bar : 0

if strategy.position_size > 0 and bars_in_trade >= i_max_hold_bars
    strategy.close("Long", comment = "TimeStop")

if strategy.position_size < 0 and bars_in_trade >= i_max_hold_bars
    strategy.close("Short", comment = "TimeStop")

if i_flat_after_session and strategy.position_size > 0 and trade_session_ended
    strategy.close("Long", comment = "SessionFlat")

if i_flat_after_session and strategy.position_size < 0 and trade_session_ended
    strategy.close("Short", comment = "SessionFlat")

if strategy.position_size == 0 and strategy.position_size[1] != 0
    active_stop := na
    active_target := na
    active_entry_bar := na

//------------------------------------------------------------------------------
// Visuals
//------------------------------------------------------------------------------
plot(vwap_val, "VWAP", color = color.new(color.blue, 0))
plot(range_ready ? day_range_high : na, "Range High", color = color.new(color.green, 30), style = plot.style_linebr)
plot(range_ready ? day_range_low : na, "Range Low", color = color.new(color.red, 30), style = plot.style_linebr)

plotshape(long_sweep, title = "Long Sweep", style = shape.circle, location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny)
plotshape(short_sweep, title = "Short Sweep", style = shape.circle, location = location.abovebar, color = color.new(color.red, 0), size = size.tiny)
plotshape(long_signal, title = "Long Entry", style = shape.triangleup, location = location.belowbar, color = color.new(color.green, 0), size = size.tiny, text = "L")
plotshape(short_signal, title = "Short Entry", style = shape.triangledown, location = location.abovebar, color = color.new(color.maroon, 0), size = size.tiny, text = "S")

bgcolor(in_range ? color.new(color.yellow, 92) : na, title = "Range Session")
